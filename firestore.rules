rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function canAccessOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isValidTimestamps() {
      return request.resource.data.keys().hasAll(['createdAt', 'updatedAt']);
    }

    match /friends/{friendId} {
      allow read: if canAccessOwner(resource.data.ownerId);

      allow create: if canAccessOwner(request.resource.data.ownerId)
        && request.resource.data.keys().hasOnly([
          'ownerId',
          'name',
          'email',
          'note',
          'status',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.note is string
        && request.resource.data.status is string
        && isValidTimestamps();

      allow update: if canAccessOwner(resource.data.ownerId)
        && canAccessOwner(request.resource.data.ownerId)
        && request.resource.data.keys().hasOnly([
          'ownerId',
          'name',
          'email',
          'note',
          'status',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.note is string
        && request.resource.data.status is string;

      allow delete: if canAccessOwner(resource.data.ownerId);
    }

    match /groups/{groupId} {
      allow read: if canAccessOwner(resource.data.ownerId);

      allow create: if canAccessOwner(request.resource.data.ownerId)
        && request.resource.data.keys().hasOnly([
          'ownerId',
          'name',
          'description',
          'members',
          'expenses',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.name is string
        && request.resource.data.description is string
        && request.resource.data.members is list
        && request.resource.data.expenses is list
        && isValidTimestamps();

      allow update: if canAccessOwner(resource.data.ownerId)
        && canAccessOwner(request.resource.data.ownerId)
        && request.resource.data.keys().hasOnly([
          'ownerId',
          'name',
          'description',
          'members',
          'expenses',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.name is string
        && request.resource.data.description is string
        && request.resource.data.members is list
        && request.resource.data.expenses is list;

      allow delete: if canAccessOwner(resource.data.ownerId);
    }
  }
}