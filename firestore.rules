rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function canAccessOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isFriendParticipant(data) {
      return isSignedIn()
        && data.keys().hasAll(['requesterId', 'recipientId'])
        && (request.auth.uid == data.requesterId || request.auth.uid == data.recipientId);
    }

    function isGroupMember(data) {
      return isSignedIn()
        && data.keys().hasAll(['memberIds'])
        && data.memberIds is list
        && data.memberIds.hasAny([request.auth.uid]);
    }

    function isValidTimestamps() {
      return request.resource.data.keys().hasAll(['createdAt', 'updatedAt']);
    }

    match /users/{userId} {
      allow read: if isSignedIn();

      allow create, update: if isSelf(userId)
        && request.resource.data.keys().hasOnly([
          'uid',
          'name',
          'email',
          'emailLower',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.uid == userId
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.emailLower is string
        && isValidTimestamps();

      allow delete: if false;
    }

    match /friendRequests/{requestId} {
      allow read: if isFriendParticipant(resource.data);

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'requesterId',
          'requesterName',
          'requesterEmail',
          'recipientId',
          'recipientName',
          'recipientEmail',
          'status',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.recipientId is string
        && request.resource.data.recipientId != request.auth.uid
        && request.resource.data.requesterName is string
        && request.resource.data.requesterEmail is string
        && request.resource.data.recipientName is string
        && request.resource.data.recipientEmail is string
        && request.resource.data.status == 'pending'
        && isValidTimestamps();

      allow update: if isFriendParticipant(resource.data)
        && request.resource.data.keys().hasOnly([
          'requesterId',
          'requesterName',
          'requesterEmail',
          'recipientId',
          'recipientName',
          'recipientEmail',
          'status',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.requesterId == resource.data.requesterId
        && request.resource.data.recipientId == resource.data.recipientId
        && request.resource.data.requesterName is string
        && request.resource.data.requesterEmail is string
        && request.resource.data.recipientName is string
        && request.resource.data.recipientEmail is string
        && request.resource.data.status is string;

      allow delete: if false;
    }

    match /friendships/{friendshipId} {
      allow read: if isSignedIn()
        && resource.data.keys().hasAll(['userIds'])
        && resource.data.userIds is list
        && resource.data.userIds.hasAny([request.auth.uid]);

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'userIds',
          'users',
          'status',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.userIds is list
        && request.resource.data.userIds.size() == 2
        && request.resource.data.userIds.hasAny([request.auth.uid])
        && request.resource.data.users is map
        && request.resource.data.status == 'accepted'
        && isValidTimestamps();

      allow update: if false;

      allow delete: if isSignedIn()
        && resource.data.keys().hasAll(['userIds'])
        && resource.data.userIds is list
        && resource.data.userIds.hasAny([request.auth.uid]);
    }

    match /groups/{groupId} {
      allow read: if isGroupMember(resource.data);

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'createdBy',
          'name',
          'description',
          'memberIds',
          'members',
          'expenses',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.description is string
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.hasAny([request.auth.uid])
        && request.resource.data.members is list
        && request.resource.data.expenses is list
        && isValidTimestamps();

      allow update: if isGroupMember(resource.data)
        && isGroupMember(request.resource.data)
        && request.resource.data.keys().hasOnly([
          'createdBy',
          'name',
          'description',
          'memberIds',
          'members',
          'expenses',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.memberIds == resource.data.memberIds
        && request.resource.data.name is string
        && request.resource.data.description is string
        && request.resource.data.memberIds is list
        && request.resource.data.members is list
        && request.resource.data.expenses is list;

      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }
  }
}